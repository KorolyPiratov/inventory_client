<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="inventory_client.controller.MainController"
            style="-fx-background-color: #f5f5f5; -fx-font-family: 'System';">

    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10 15 10 15;" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Система учёта вещей"
                       style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="⟳ Обновить" onAction="#handleRefresh"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white;
                               -fx-font-size: 13; -fx-padding: 7 14; -fx-cursor: hand;
                               -fx-background-radius: 6;"/>
                <Button text="+ Добавить" onAction="#handleAdd"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-font-size: 13; -fx-padding: 7 14; -fx-cursor: hand;
                               -fx-background-radius: 6;"/>
                <Button text="⚙ Настройки" onAction="#handleSettings"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                               -fx-font-size: 13; -fx-padding: 7 14; -fx-cursor: hand;
                               -fx-background-radius: 6;"/>
                <Button text="Выйти" onAction="#handleLogout"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                               -fx-font-size: 13; -fx-padding: 7 14; -fx-cursor: hand;
                               -fx-background-radius: 6;"/>
            </HBox>
            <HBox fx:id="topSearchBox" spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Поиск по названию..."
                           prefWidth="260" style="-fx-font-size: 13; -fx-padding: 6;
                           -fx-background-radius: 6;"
                           onKeyReleased="#handleSearchTyped"/>
                <Button text="Сбросить всё" onAction="#handleReset"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                               -fx-padding: 6 12; -fx-cursor: hand; -fx-background-radius: 6;
                               -fx-font-size: 13;"/>
            </HBox>
            <!-- Поиск по архиву — скрыт по умолчанию -->
            <VBox fx:id="archiveSearchBox" spacing="8" alignment="CENTER_LEFT"
                  managed="false" visible="false">
                <TextField fx:id="archiveSearchField" promptText="Поиск по вещи или получателю..."
                           prefWidth="320" style="-fx-font-size: 13; -fx-padding: 6;
                           -fx-background-radius: 6;"
                           onKeyReleased="#handleArchiveSearch"/>
            </VBox>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
                 onMouseClicked="#handleTabChanged">

            <Tab text="Склад">
                <TableView fx:id="itemsTable" style="-fx-font-size: 13;"
                           onMouseClicked="#handleRowClick">
                    <columns>
                        <TableColumn fx:id="nameCol" text="Название" prefWidth="200"/>
                        <TableColumn fx:id="categoryCol" text="Категория" prefWidth="110"/>
                        <TableColumn fx:id="colorCol" text="Цвет" prefWidth="100"/>
                        <TableColumn fx:id="boxCol" text="№ Коробки" prefWidth="100"/>
                        <TableColumn fx:id="supplyDateCol" text="Дата поставки" prefWidth="130"/>
                        <TableColumn fx:id="quantityCol" text="Кол-во" prefWidth="70"/>
                        <TableColumn fx:id="printerCol" text="Принтер" prefWidth="130"/>
                    </columns>
                </TableView>
            </Tab>

            <Tab text="Архив" onSelectionChanged="#handleArchiveTabSelected">
                <TableView fx:id="archiveTable" style="-fx-font-size: 13;">
                    <columns>
                        <TableColumn fx:id="archiveItemCol" text="Вещь" prefWidth="170"/>
                        <TableColumn fx:id="archivePersonCol" text="Кому выдано" prefWidth="150"/>
                        <TableColumn fx:id="archivePrinterCol" text="Принтер" prefWidth="130"/>
                        <TableColumn fx:id="archiveDateCol" text="Дата выдачи" prefWidth="115"/>
                        <TableColumn fx:id="archiveIndefiniteCol" text="Бессрочно" prefWidth="85"/>
                        <TableColumn fx:id="archiveReturnDateCol" text="Дата возврата" prefWidth="115"/>
                    </columns>
                </TableView>
            </Tab>

        </TabPane>
    </center>

    <right>
        <VBox fx:id="filtersPanel"
              style="-fx-background-color: #ecf0f1; -fx-padding: 15;
                     -fx-border-color: #bdc3c7; -fx-border-width: 0 0 0 1;"
              spacing="10" prefWidth="210">

            <Label text="Фильтры"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Separator/>

            <Label text="Категория:"
                   style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13;"/>
            <ComboBox fx:id="categoryFilter" promptText="Все категории"
                      maxWidth="Infinity" style="-fx-font-size: 13;"
                      onAction="#handleFilterChanged"/>

            <Label text="Цвет картриджа:"
                   style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13;"/>
            <ComboBox fx:id="colorFilter" promptText="Все цвета"
                      maxWidth="Infinity" style="-fx-font-size: 13;"
                      onAction="#handleFilterChanged"/>

            <Separator/>

            <Label text="№ Коробки:"
                   style="-fx-font-weight: bold; -fx-text-fill: #34495e; -fx-font-size: 13;"/>
            <TextField fx:id="boxFilter" promptText="Поиск по коробке..."
                       style="-fx-font-size: 13; -fx-padding: 5; -fx-background-radius: 6;"
                       onKeyReleased="#handleFilterChanged"/>

            <Separator/>

            <Button text="Сбросить фильтры" onAction="#handleReset"
                    maxWidth="Infinity"
                    style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                           -fx-padding: 8; -fx-cursor: hand; -fx-background-radius: 6;
                           -fx-font-size: 13;"/>
        </VBox>
    </right>

    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 8 15;"
              alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" text="Загрузка..."
                   style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
        </HBox>
    </bottom>
</BorderPane>