<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="inventory_client.controller.LoginController"
      alignment="CENTER" spacing="15"
      style="-fx-background-color: #f5f5f5; -fx-padding: 40;">

    <Label text="Система учёта"
           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Вход в систему"
           style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;"/>

    <VBox spacing="8" maxWidth="280">
        <TextField fx:id="usernameField"
                   promptText="Логин"
                   style="-fx-font-size: 14; -fx-padding: 8;"/>

        <PasswordField fx:id="passwordField"
                       promptText="Пароль"
                       style="-fx-font-size: 14; -fx-padding: 8;"/>

        <Label fx:id="errorLabel"
               style="-fx-text-fill: red; -fx-font-size: 12;"
               text=""/>

        <Button fx:id="loginButton"
                text="Войти"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-padding: 10; -fx-cursor: hand;
                       -fx-background-radius: 5;"/>
        <Label text="Сменить сервер"
               onMouseClicked="#handleChangeServer"
               style="-fx-text-fill: #3498db; -fx-font-size: 12;
                      -fx-cursor: hand; -fx-underline: true;"
               alignment="CENTER" maxWidth="Infinity"/>
    </VBox>
</VBox>