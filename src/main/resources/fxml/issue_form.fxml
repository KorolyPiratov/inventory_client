<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="inventory_client.controller.IssueFormController"
      spacing="12" minWidth="400" minHeight="370"
      style="-fx-padding: 25; -fx-background-color: #f5f5f5;">

    <Label fx:id="titleLabel"
           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <VBox style="-fx-background-color: white; -fx-padding: 15;
                 -fx-background-radius: 8;" spacing="10">

        <Label text="ФИО получателя:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="fullNameField" promptText="Введите ФИО..."
                   style="-fx-font-size: 13; -fx-padding: 6;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Дата выдачи:" style="-fx-font-weight: bold;"/>
            <Label fx:id="dateLabel"
                   style="-fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
        </HBox>

        <CheckBox fx:id="indefiniteCheck"
                  text="Бессрочная выдача"
                  onAction="#handleIndefiniteChanged"
                  style="-fx-font-size: 13;"/>

        <VBox fx:id="returnDateBox" spacing="5">
            <Label text="Дата возврата:" style="-fx-font-weight: bold;"/>
            <DatePicker fx:id="returnDatePicker" maxWidth="Infinity"/>
        </VBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <CheckBox fx:id="printCheck"
                      text="Распечатать бланк"
                      style="-fx-font-size: 13;"/>
            <Button fx:id="templateButton"
                    text="Шаблон"
                    onAction="#handleChooseTemplate"
                    style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50;
                           -fx-font-size: 12; -fx-padding: 4 12; -fx-cursor: hand;
                           -fx-background-radius: 5; -fx-border-color: #bdc3c7;
                           -fx-border-radius: 5;"/>
            <Label fx:id="templateNameLabel"
                   style="-fx-text-fill: #7f8c8d; -fx-font-size: 11;"
                   text="дефолтный шаблон"/>
        </HBox>
    </VBox>

    <Label fx:id="errorLabel"
           style="-fx-text-fill: red; -fx-font-size: 12;" text=""/>

    <HBox spacing="10">
        <Button text="Выдать" onAction="#handleConfirm"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-padding: 8 25; -fx-cursor: hand;
                       -fx-background-radius: 5;"/>
        <Button text="Отмена" onAction="#handleCancel"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-padding: 8 25; -fx-cursor: hand;
                       -fx-background-radius: 5;"/>
    </HBox>
</VBox>