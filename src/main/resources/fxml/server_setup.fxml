<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="inventory_client.controller.ServerSetupController"
      spacing="16" alignment="CENTER"
      style="-fx-padding: 40;">

    <Label text="Добро пожаловать!" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
    <Label text="Введите IP-адрес сервера для подключения:"
           style="-fx-text-fill: #555;"/>

    <TextField fx:id="ipField"
               promptText="Например: 192.168.1.100"
               maxWidth="280"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <Button text="Подключиться"
            onAction="#handleConnect"
            defaultButton="true"
            maxWidth="280"
            style="-fx-font-size: 14;"/>
</VBox>