<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="inventory_client.controller.ItemDetailController"
      spacing="10" style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <!-- Заголовок -->
    <Label fx:id="titleLabel"
           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <!-- Информация -->
    <VBox style="-fx-background-color: white; -fx-padding: 15;
                 -fx-background-radius: 8;" spacing="6">
        <HBox spacing="10">
            <Label text="Категория:" style="-fx-font-weight: bold;"/>
            <Label fx:id="categoryLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Тип:" style="-fx-font-weight: bold;"/>
            <Label fx:id="colorLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Дата поставки:" style="-fx-font-weight: bold;"/>
            <Label fx:id="manufacturerLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="№ Коробки:" style="-fx-font-weight: bold;"/>
            <Label fx:id="boxLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Количество:" style="-fx-font-weight: bold;"/>
            <Label fx:id="quantityLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Описание:" style="-fx-font-weight: bold;"/>
            <Label fx:id="descriptionLabel" wrapText="true"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Принтер:" style="-fx-font-weight: bold;"/>
            <Label fx:id="printerLabel"/>
        </HBox>
    </VBox>

    <!-- Кнопки действий -->
    <HBox spacing="10">
        <Button text="Выдать" onAction="#handleIssue"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;
                       -fx-background-radius: 5;"/>
        <Button text="Редактировать" onAction="#handleEdit"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;
                       -fx-background-radius: 5;"/>
        <Button text="Удалить" onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                   -fx-font-size: 13; -fx-padding: 8 20; -fx-cursor: hand;
                   -fx-background-radius: 5;"/>
    </HBox>

    <!-- История выдач -->
    <Label text="История выдач"
           style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <TableView fx:id="issuanceTable" prefHeight="180">
        <columns>
            <TableColumn fx:id="fullNameCol" text="ФИО" prefWidth="200"/>
            <TableColumn fx:id="dateCol" text="Дата" prefWidth="100"/>
            <TableColumn fx:id="indefiniteCol" text="Бессрочно" prefWidth="90"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel" style="-fx-text-fill: red;"/>
</VBox>