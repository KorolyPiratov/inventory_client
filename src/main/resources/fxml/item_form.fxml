<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="inventory_client.controller.ItemFormController"
      spacing="10" style="-fx-padding: 20; -fx-background-color: #f5f5f5;
                          -fx-font-family: 'System';">

    <Label fx:id="titleLabel"
           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <VBox fx:id="returnDateBox" spacing="5" managed="false" visible="false">
        <Label text="Дата возврата:" style="-fx-font-weight: bold;"/>
        <DatePicker fx:id="returnDatePicker" maxWidth="Infinity"/>
    </VBox>

    <VBox style="-fx-background-color: white; -fx-padding: 15;
                 -fx-background-radius: 8;" spacing="8">

        <Label text="Название:" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
        <TextField fx:id="nameField" promptText="Название вещи"
                   style="-fx-font-size: 13; -fx-padding: 6; -fx-background-radius: 5;"/>

        <Label text="Категория:" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
        <ComboBox fx:id="categoryField" promptText="Выберите категорию"
                  maxWidth="Infinity" style="-fx-font-size: 13;"
                  onAction="#handleCategoryChanged"/>

        <TextField fx:id="customCategoryField"
                   promptText="Введите свою категорию..."
                   style="-fx-font-size: 13; -fx-padding: 6; -fx-background-radius: 5;"
                   managed="false" visible="false"/>

        <Label text="Цвет картриджа:" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
        <ComboBox fx:id="colorField" promptText="Выберите цвет"
                  maxWidth="Infinity" style="-fx-font-size: 13;"/>

        <Label text="№ Коробки:" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
        <TextField fx:id="boxField" promptText="Номер коробки"
                   style="-fx-font-size: 13; -fx-padding: 6; -fx-background-radius: 5;"/>

        <Label text="Количество:" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
        <TextField fx:id="quantityField" promptText="0"
                   style="-fx-font-size: 13; -fx-padding: 6; -fx-background-radius: 5;"/>

        <Label text="Дата поставки:" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
        <DatePicker fx:id="supplyDateField" maxWidth="Infinity"
                    style="-fx-font-size: 13;"/>

        <Label text="Принтер:" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
        <TextField fx:id="printerField" promptText="Название принтера"
                   style="-fx-font-size: 13; -fx-padding: 6; -fx-background-radius: 5;"/>

        <Label text="Описание:" style="-fx-font-weight: bold; -fx-font-size: 13;"/>
        <TextArea fx:id="descriptionField" promptText="Описание..."
                  prefHeight="70" style="-fx-font-size: 13;"/>
    </VBox>

    <Label fx:id="errorLabel"
           style="-fx-text-fill: red; -fx-font-size: 12;" text=""/>

    <HBox spacing="10">
        <Button text="Сохранить" onAction="#handleSave"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-padding: 8 25; -fx-cursor: hand;
                       -fx-background-radius: 6;"/>
        <Button text="Отмена" onAction="#handleCancel"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-padding: 8 25; -fx-cursor: hand;
                       -fx-background-radius: 6;"/>
    </HBox>
</VBox>